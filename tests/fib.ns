// ALGORITHMIC:
// avoids list builder loop using $last function
t = $clock();
$ println(
    ((tmp1, tmp2, tmp3, c, until) ->
            $last(((c += 1) <= until)::
                (tmp3 = (tmp1 = tmp2)+(tmp2 = tmp3))
        )
    )(0, 0, 1, 0, 2600000)
);
// can generate over 2.6 million in a second
// fib(n) but can be configured to produce a list instead, very fast.
// I don't know why you'd want such a high fibonacci number though, it's infinity after like 3000
$ println($clock()-t);

// RECURSIVE:
$ println(
    (fib = (x) ->
        (x <= 1) ? 1 : fib(x-1)+fib(x-2)
    )(10)
);
// crashes (stack overflow), very slow, generates only fib(n)

// ITERATIVE:
// we use a literal instead of an argument here, as the constant folder will optimize it away
// same $last() trick as before
t = $clock();
$ println(
    ((tmp1, tmp2, tmp3) ->
                $last((tmp3 = (tmp1 = tmp2)+(tmp2 = tmp3)) for counter in $step(0..2600000, 1))
        )(0, 0, 1)
);
// equally fast to ALGORITHMIC, sometimes even faster. In some tests, the difference can be up to 40%
// the compiler optimizes the for loop away and turns it into a simple incrementing loop variable, which makes this more powerful
$ println($clock() - t);