// ALGORITHMIC:
t = $clock();
$ println(
    ((tmp1, tmp2, tmp3, c) ->
        ((until) ->
            $last((c <= until)::
                tmp3
                    + 0*(c += 1)
                    + 0*(tmp3 = (tmp1 = tmp2)+(tmp2 = tmp3)))
        )
    )(0, 0, 1, 1)(1000000)
); // can generate over 1000000 in a second, fib(n) but can be configured to produce a list instead, very fast
$ println($clock()-t);
// RECURSIVE:
$ println(
    (fib = (x) ->
        (x <= 1) ? 1 : fib(x-1)+fib(x-2)
    )(10)
); // crashes (stack overflow), very slow, generates only fib(n)