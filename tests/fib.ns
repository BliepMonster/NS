// ALGORITHMIC:
// avoids list builder loop using $last function
t = $clock();
$ println(
    ((tmp1, tmp2, tmp3, c, until) ->
            $last(((c += 1) <= until)::
                tmp3 = (tmp1 = tmp2)+(tmp2 = tmp3)
        )
    )(0, 0, 1, 0, 2600000)
);
// can generate over 2.6 million in a second
// fib(n) but can be configured to produce a list instead, very fast.
// I don't know why you'd want 1500000 fibonacci though, it's infinity after like 3000
$ println($clock()-t);
// RECURSIVE:
$ println(
    (fib = (x) ->
        (x <= 1) ? 1 : fib(x-1)+fib(x-2)
    )(10)
);
// crashes (stack overflow), very slow, generates only fib(n)