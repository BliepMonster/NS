// ALGORITHMIC:
$ println(
    ((tmp1, tmp2, tmp3, c) ->
        ((until) ->
            (c <= until)::tmp3
                + 0*(c += 1)
                + (0*(tmp1 = tmp2)
                + 0*(tmp2 = tmp3)
                + 0*(tmp3 = tmp1+tmp2))
        )
    )(0, 0, 1, 1)(20)
); // can generate up to 200000 in a second, generates all items from fib(0) to fib(n)
// RECURSIVE:
$ println(
    (fib = (x) ->
        (x <= 1) ? 1 : fib(x-1)+fib(x-2)
    )(20)
); // crashes (stack overflow), very slow, generates only fib(n)